{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Paper: Build EN (author)",
      "type": "shell",
      "command": "latexmk",
      "args": [
        "-xelatex",
        "-interaction=nonstopmode",
        "-outdir=build",
        "-auxdir=build",
        "paper_author_en.tex"
      ],
      "options": {
        "cwd": "${workspaceFolder}/docs/paper-latex"
      },
      "osx": {
        "options": {
          "cwd": "${workspaceFolder}/docs/paper-latex",
          "env": {
            "PATH": "${env:PATH}:${env:HOME}/Library/TinyTeX/bin/universal-darwin"
          }
        }
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Paper: Build DE (author)",
      "type": "shell",
      "command": "latexmk",
      "args": [
        "-xelatex",
        "-interaction=nonstopmode",
        "-outdir=build",
        "-auxdir=build",
        "paper_author_de.tex"
      ],
      "options": {
        "cwd": "${workspaceFolder}/docs/paper-latex"
      },
      "osx": {
        "options": {
          "cwd": "${workspaceFolder}/docs/paper-latex",
          "env": {
            "PATH": "${env:PATH}:${env:HOME}/Library/TinyTeX/bin/universal-darwin"
          }
        }
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Paper: Clean LaTeX artifacts",
      "type": "shell",
      "command": "latexmk -C paper_author_en.tex; latexmk -C paper_author_de.tex",
      "options": {
        "cwd": "${workspaceFolder}/docs/paper-latex"
      },
      "osx": {
        "options": {
          "cwd": "${workspaceFolder}/docs/paper-latex",
          "env": {
            "PATH": "${env:PATH}:${env:HOME}/Library/TinyTeX/bin/universal-darwin"
          }
        }
      },
      "problemMatcher": []
    }
  ]
}
